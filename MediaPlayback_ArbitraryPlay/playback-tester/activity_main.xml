<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="MediaPlaybackActivityStarter 漏洞测试"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="目标: com.huawei.music\nActivity: com.android.mediacenter.ui.player.oneshot.MediaPlaybackActivityStarter"
        android:textSize="12sp"
        android:textColor="#666"
        android:paddingBottom="12dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="预置测试用例:"
        android:textSize="13sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnCase1"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="播放 file:///sdcard/ 音频"
        android:textSize="13sp"
        android:layout_marginTop="4dp" />

    <Button
        android:id="@+id/btnCase2"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="播放 content://media/ 媒体库"
        android:textSize="13sp" />

    <Button
        android:id="@+id/btnCase3"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="尝试 content:// contacts/ (非法)"
        android:textSize="13sp" />

    <Button
        android:id="@+id/btnCase4"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="尝试 content:// settings/ (非法)"
        android:textSize="13sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="自定义 URL:"
        android:textSize="13sp"
        android:textStyle="bold"
        android:paddingTop="8dp" />

    <EditText
        android:id="@+id/editTextUrl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="输入 URI (支持 file:// content://)"
        android:inputType="textUri"
        android:textSize="14sp" />

    <Button
        android:id="@+id/btnSend"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="触发播放"
        android:textSize="16sp"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="15sp"
        android:gravity="center"
        android:padding="10dp"
        android:layout_marginTop="8dp"
        android:background="#F5F5F5" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#1A1A2E"
        android:padding="6dp"
        android:layout_marginTop="6dp">

        <TextView
            android:id="@+id/logText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="日志输出...\n"
            android:textSize="11sp"
            android:textColor="#00FF00"
            android:typeface="monospace" />
    </ScrollView>

</LinearLayout>
